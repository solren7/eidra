{
  "name": "komo-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Electron desktop shell for komo. A thin host over the shared @komo/app renderer: the main process discovers the gateway (~/.komo/gateway.json) and hands the renderer {base, key}; the renderer runs the same HttpKomoClient as the web build.",
  "main": "dist/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "start": "npm run build && electron .",
    "typecheck": "tsc --noEmit",
    "postinstall": "node node_modules/electron/install.js"
  },
  "dependencies": {
    "@komo/app": "workspace:*",
    "@tanstack/react-query": "^5.100.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.4",
    "electron": "^43.2.0",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
