{
  "name": "@komo/app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Shared komo renderer — a platform-agnostic React SPA over the gateway's HTTP api channel. Mounted by both the Electron desktop shell (apps/desktop) and the standalone web build (apps/web); each host injects an HttpKomoClient with its own gateway resolver.",
  "exports": {
    ".": "./src/index.ts",
    "./styles/main.css": "./src/styles/main.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.27",
    "@assistant-ui/react-markdown": "^0.14.6",
    "@assistant-ui/react-syntax-highlighter": "^0.14.2",
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-query": "^5.100.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "typescript": "^7.0.2"
  }
}
